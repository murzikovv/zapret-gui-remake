{
  "name": "zapret-gui-remake",
  "version": "1.0.0",
  "description": "Remake of Zapret GUI in Vanilla JS",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "author": "Murzikov",
  "license": "ISC",
  "dependencies": {
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.murzikov.zapretgui",
    "productName": "Zapret GUI",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Zapret GUI",
      "include": "build/installer.nsh"
    }
  }
}
